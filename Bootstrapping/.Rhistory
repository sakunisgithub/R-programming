rm(list = ls())
set.seed(14)
n <- 100; B <- 1000; theta <- 5
x <- rnorm(n, mean = theta, sd = 1)
theta_hat <- mean(x); theta_hat
bootstrap.theta_hat <- c()
for(i in 1:B){
bootstrap.sample <- sample(x, size = n, replace = TRUE)
bootstrap.theta_hat[i] <- mean(bootstrap.sample)
}
head(bootstrap.theta_hat)
library(tidyverse)
data.frame(bootstrap.theta_hat) %>%
ggplot(aes(x = bootstrap.theta_hat)) +
geom_histogram(aes(y = after_stat(density)), bins = 15,
fill = "#3CF527", color = "black", linewidth = 1) +
stat_function(fun = dnorm, args = list(mean = theta_hat, sd = 0.1),
linewidth = 1.25, color = "blue") +
labs(x = expression(hat(theta)),
title = "Approximate Sampling Distribution based on Bootstrap Samples")
data.frame(bootstrap.theta_hat) %>%
ggplot(aes(x = bootstrap.theta_hat)) +
geom_histogram(aes(y = after_stat(density)), bins = 15,
fill = "#3CF527", color = "black", linewidth = 1) +
stat_function(fun = dnorm, args = list(mean = 5, sd = 0.1),
linewidth = 1.25, color = "blue") +
labs(x = expression(hat(theta)),
title = "Approximate Sampling Distribution based on Bootstrap Samples")
n <- 361
angles <- seq(0, 2 * pi, length.out = n)
numbers <- runif(n)
x <- cos(angles) * numbers
y <- sin(angles) * numbers
plot(NA, NA,
xlim = c(-1, 1), ylim = c(-1, 1),
xlab = "", ylab = "")
points(x, y)
segments(0, 0, x, y)
